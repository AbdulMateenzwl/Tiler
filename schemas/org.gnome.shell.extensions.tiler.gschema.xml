
<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
    <schema id="org.gnome.shell.extensions.tiler" path="/org/gnome/shell/extensions/tiler/">

        <!-- Appearance -->
        <key name="border-width" type="i">
            <default>2</default>
            <summary>Border width in pixels</summary>
        </key>
        <key name="border-radius" type="i">
            <default>12</default>
            <summary>Border radius in pixels</summary>
        </key>
        <key name="border-color-focused" type="s">
            <default>'#6496ff'</default>
            <summary>Border color for focused window</summary>
        </key>
        <key name="border-color-tiled" type="s">
            <default>'rgba(235, 235, 235, 0.85)'</default>
            <summary>Border color for tiled window</summary>
        </key>
        <key name="border-color-floating" type="s">
            <default>'#ffb432'</default>
            <summary>Border color for floating window</summary>
        </key>
        <key name="gap-size" type="i">
            <default>8</default>
            <summary>Gap between windows in pixels</summary>
        </key>

        <!-- Behaviour -->
        <key name="float-window-width" type="i">
            <default>800</default>
            <summary>Floating window default width</summary>
        </key>
        <key name="float-window-height" type="i">
            <default>600</default>
            <summary>Floating window default height</summary>
        </key>
        <key name="resize-step-h" type="i">
            <default>50</default>
            <summary>Horizontal resize step in pixels</summary>
        </key>
        <key name="resize-step-v" type="i">
            <default>50</default>
            <summary>Vertical resize step in pixels</summary>
        </key>

        <!-- Keybindings -->

        <key name="retile-windows" type="as">
            <default>['&lt;Super&gt;&lt;Alt&gt;t']</default>
            <summary>Retile all windows</summary>
        </key>
        <key name="split-horizontal" type="as">
            <default>['&lt;Super&gt;&lt;Shift&gt;b']</default>
            <summary>Split next window horizontally</summary>
        </key>
        <key name="split-vertical" type="as">
            <default>['&lt;Super&gt;&lt;Shift&gt;v']</default>
            <summary>Split next window vertically</summary>
        </key>
        <key name="toggle-float" type="as">
            <default>['&lt;Super&gt;f']</default>
            <summary>Toggle window floating</summary>
        </key>
        <key name="drag-mode-swap" type="as">
            <default>['&lt;Super&gt;&lt;Shift&gt;c']</default>
            <summary>Set drag mode to swap</summary>
        </key>
        <key name="drag-mode-insert" type="as">
            <default>['&lt;Super&gt;&lt;Shift&gt;x']</default>
            <summary>Set drag mode to insert</summary>
        </key>
        <key name="focus-left" type="as">
            <default>['&lt;Super&gt;h']</default>
            <summary>Focus window to the left</summary>
        </key>
        <key name="focus-right" type="as">
            <default>['&lt;Super&gt;l']</default>
            <summary>Focus window to the right</summary>
        </key>
        <key name="focus-up" type="as">
            <default>['&lt;Super&gt;k']</default>
            <summary>Focus window above</summary>
        </key>
        <key name="focus-down" type="as">
            <default>['&lt;Super&gt;j']</default>
            <summary>Focus window below</summary>
        </key>
        <key name="toggle-resize-mode" type="as">
            <default>['&lt;Super&gt;Return']</default>
            <summary>Toggle keyboard resize mode</summary>
        </key>
        <key name="resize-left" type="as">
            <default>['&lt;Super&gt;&lt;Shift&gt;h']</default>
            <summary>Resize window left (grow left)</summary>
        </key>
        <key name="resize-right" type="as">
            <default>['&lt;Super&gt;&lt;Shift&gt;l']</default>
            <summary>Resize window right (grow right)</summary>
        </key>
        <key name="resize-up" type="as">
            <default>['&lt;Super&gt;&lt;Shift&gt;k']</default>
            <summary>Resize window up (grow up)</summary>
        </key>
        <key name="resize-down" type="as">
            <default>['&lt;Super&gt;&lt;Shift&gt;j']</default>
            <summary>Resize window down (grow down)</summary>
        </key>
    </schema>
</schemalist>